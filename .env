# OpenClaw Next Environment Configuration
# Copy this file to .env and fill in your actual values

# ============================================================================
# Gateway Configuration
# ============================================================================

# WebSocket Gateway URL for agent communication
VITE_GATEWAY_URL=ws://localhost:18789

# Authentication token for gateway (leave empty for no auth)
VITE_GATEWAY_TOKEN=your-secure-token-here

# ============================================================================
# Ollama Configuration (Local)
# ============================================================================

# Ollama local endpoint (default: http://localhost:11434)
VITE_OLLAMA_ENDPOINT=http://localhost:11434

# Default model to use for local Ollama
VITE_OLLAMA_MODEL=llama3.2

# ============================================================================
# Ollama Cloud Configuration (Optional)
# ============================================================================

# Enable Ollama Cloud (set to 'true' to enable)
VITE_OLLAMA_CLOUD_ENABLED=false

# Ollama Cloud API Key (from https://ollama.com)
VITE_OLLAMA_CLOUD_API_KEY=your-ollama-cloud-api-key

# Ollama Cloud endpoint
VITE_OLLAMA_CLOUD_ENDPOINT=https://api.ollama.com

# Default model for Ollama Cloud
VITE_OLLAMA_CLOUD_MODEL=llama3.1

# ============================================================================
# Provider API Keys (Optional)
# Add keys for providers you want to use alongside Ollama
# ============================================================================

# OpenAI API Key
VITE_OPENAI_API_KEY=your-openai-api-key

# Anthropic API Key (for Claude models)
VITE_ANTHROPIC_API_KEY=your-anthropic-api-key

# Groq API Key (for fast inference)
VITE_GROQ_API_KEY=your-groq-api-key

# Google/Gemini API Key
VITE_GEMINI_API_KEY=your-gemini-api-key

# ============================================================================
# Advanced Configuration
# ============================================================================

# API request timeout in milliseconds
VITE_API_TIMEOUT=30000

# Enable debug logging
VITE_DEBUG=false

# Application environment
VITE_NODE_ENV=development
