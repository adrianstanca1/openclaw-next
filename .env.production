# OpenClaw Next - Production Environment
NODE_ENV=production

# ============================================================================
# Gateway Configuration
# ============================================================================
# WebSocket Gateway URL (use wss:// for HTTPS)
VITE_GATEWAY_URL=wss://your-vps-domain.com/api

# Authentication token (generate a secure random string)
VITE_GATEWAY_TOKEN=your-secure-production-token-here

# ============================================================================
# Ollama Configuration
# ============================================================================
# Local Ollama (if running on same VPS)
VITE_OLLAMA_ENDPOINT=http://localhost:11434
VITE_OLLAMA_MODEL=llama3.2

# Ollama Cloud (optional)
VITE_OLLAMA_CLOUD_ENABLED=false
VITE_OLLAMA_CLOUD_API_KEY=
VITE_OLLAMA_CLOUD_ENDPOINT=https://api.ollama.com
VITE_OLLAMA_CLOUD_MODEL=llama3.1

# ============================================================================
# Provider API Keys (Add your production keys)
# ============================================================================
VITE_OPENAI_API_KEY=
VITE_ANTHROPIC_API_KEY=
VITE_GROQ_API_KEY=
VITE_GEMINI_API_KEY=

# ============================================================================
# Advanced Configuration
# ============================================================================
VITE_API_TIMEOUT=30000
VITE_DEBUG=false
