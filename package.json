    "cors": "^2.8.6",
    "date-fns": "^4.1.0",
    "express": "^5.2.1",
    "framer-motion": "^11.11.11",
    "immer": "^10.1.1",
    "lit": "^3.1.4",
    "lucide-react": "^0.575.0",
    "nanoid": "^5.0.7",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^3.7.0",
    "uuid": "^13.0.0",
